NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
JWT_SECRET="cambiar-en-produccion-string-largo-y-aleatorio"
# YouTube Data API v3 — console.cloud.google.com → Credenciales → Clave de API
YOUTUBE_API_KEY=""

# Revalidación ISR — mismo valor que REVALIDATE_SECRET del backend
REVALIDATE_SECRET=""

# ── Auth0 (V2 — solo médicos; el admin sigue con su auth propia) ──
# Dashboard de Auth0 → Applications → tu app (Regular Web App) → Settings
AUTH0_SECRET=""                                   # string aleatorio: openssl rand -hex 32
AUTH0_BASE_URL="http://localhost:3000"            # en producción: https://reportemedico.com
AUTH0_ISSUER_BASE_URL="https://TU-DOMINIO.us.auth0.com"  # el "Domain" con https:// adelante
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_AUDIENCE="https://api.reportemedico.com"    # el Identifier de la API que creás en Auth0
